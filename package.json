{
    "name": "@kayahr/oxlint-config",
    "version": "1.31.1",
    "description": "Shared oxlint config for @kayahr projects",
    "type": "module",
    "exports": "./.oxlintrc.json",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kayahr/oxlint-config.git"
    },
    "funding": "https://github.com/kayahr/oxlint-config?sponsor=1",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc",
        "prepare": "run build",
        "test": "run test:*",
        "test:lint": "oxlint --type-aware --deny-warnings",
        "test:spell": "cspell --color --no-progress"
    },
    "files": [
        ".oxlintrc.json"
    ],
    "devDependencies": {
        "@kayahr/cspell": "9.7.0-bundle.1",
        "@kayahr/npm-utils": "1.1.2",
        "@types/node": "25.6.0",
        "typescript": "6.0.2"
    },
    "dependencies": {
        "oxlint": "^1.59.0",
        "oxlint-tsgolint": "^0.20.0"
    }
}
